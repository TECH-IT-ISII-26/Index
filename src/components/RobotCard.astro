---
interface Props {
  name: string;
  description: string;
  imageUrl: string;
  link: string;
  delay?: number;
}

const { name, description, imageUrl, link, delay = 0 } = Astro.props;
---

<a href={link} class="block">
  <div
    class="relative bg-gray-800 border border-cyan-700 rounded-lg p-6 flex flex-col items-center
           glow-effect hover:shadow-cyan-500/50 transition-all duration-300 h-full
           animate-fade-in-up"
    style={{ animationDelay: `${delay}ms` }}
  >
    <img src={imageUrl} alt={name} class="w-32 h-32 object-contain mb-4 filter drop-shadow-[0_0_8px_rgba(0,255,255,0.6)]" />
    <h3 class="text-2xl font-orbitron text-cyan-400 mb-2">{name}</h3>
    <p class="text-gray-300 text-center text-sm grow">{description}</p>
    <span class="mt-4 text-cyan-300 hover:text-cyan-100 transition-colors duration-300 text-sm">
      Scopri di più &rarr;
    </span>
  </div>
</a>

<style>
  /* Keyframe */
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
    opacity: 0;
  }
</style>