---
interface Props {
  year: string;
  name: string;
  specs: string[];
  image: string;
  side: 'left' | 'right';
}
const { year, name, specs, image, side } = Astro.props;
---

<div class={`flex flex-col ${side === 'right' ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-12 my-32 opacity-0 translate-y-10 transition-all duration-1000 ease-out reveal-on-scroll`}>
  <div class="flex-1 text-center md:text-left">
    <span class="text-6xl font-bold text-white/10 font-orbitron block leading-none">{year}</span>
    <h3 class="text-4xl font-bold text-[--color-neon-cyan] -mt-8 mb-6">{name}</h3>
    <ul class="space-y-3 text-slate-400">
      {specs.map(spec => (
        <li class="flex items-center gap-2">
          <span class="w-2 h-2 bg-[--color-neon-cyan] rotate-45"></span> {spec}
        </li>
      ))}
    </ul>
  </div>
  <div class="flex-1 relative group">
    <div class="absolute -inset-1 bg-linear-to-r from-[--color-neon-cyan] to-[--color-neon-purple] rounded-lg blur opacity-25 group-hover:opacity-100 transition duration-1000"></div>
    <div class="relative bg-black rounded-lg overflow-hidden border border-white/10">
      <img src={image} alt={name} class="w-full h-80 object-cover grayscale hover:grayscale-0 transition-all duration-700" />
    </div>
  </div>
</div>