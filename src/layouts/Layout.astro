---
import { ViewTransitions } from 'astro:transitions';
import '../styles/globals.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Sito web del team di robotica" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="bg-gray-950 text-gray-100 font-roboto-mono antialiased">
    <header class="fixed top-0 left-0 w-full z-50 bg-gray-950/80 backdrop-blur-sm shadow-lg">
      <nav class="container mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-orbitron text-cyan-400 hover:text-cyan-200 transition-colors duration-300">
          RoboSellers
        </a>
        <div class="space-x-8 hidden md:flex">
          <a href="/#about" class="text-gray-200 hover:text-cyan-400 transition-colors duration-300">About us</a>
          <a href="/#robots" class="text-gray-200 hover:text-cyan-400 transition-colors duration-300">Our Robots</a>
          <a href="/#team" class="text-gray-200 hover:text-cyan-400 transition-colors duration-300">The Team</a>
          <a href="/#contact" class="text-gray-200 hover:text-cyan-400 transition-colors duration-300">Contact us</a>
        </div>
        </nav>
    </header>

    <main>
      <slot />
    </main>

<footer class="bg-gray-950 text-gray-400 py-10 text-center border-t border-white/5">
  <div class="container mx-auto px-6">
    <p class="text-sm md:text-base mb-2">
      &copy; {new Date().getFullYear()} <span class="text-white font-orbitron">Tech It ISII</span>. All rights reserved.
    </p>
    
    <div class="flex items-center justify-center gap-2 text-sm">
      <span>Made with ❤️</span>
      <span>by</span>
      <a 
        href="https://itslucaa.is-a.dev" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-[--color-neon-blue] hover:text-white transition-colors duration-300 font-bold underline decoration-dotted underline-offset-4"
      >
        ItsLucaa
      </a>
    </div>
  </div>
</footer>

<style>
  .rendering-pixelated {
    image-rendering: pixelated;
  }
</style>
  </body>
</html>